# .env.local.example
# Copy this file to .env.local and fill in values before running

# ── Site URL (no trailing slash) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email notifications (optional — see src/app/api/contact/route.ts) ──────
# Uncomment and fill these in to enable email notifications from the contact form
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_TO=siddiqueshazib5@gmail.com

# ── Analytics (optional) ──────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
