# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env.local for local development
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Site URL (used in sitemap, OG tags, canonical URLs) ──────────────────────
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Calendly Booking Link ─────────────────────────────────────────────────────
# Update in src/lib/config.ts AND here for consistency
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link

# ── Contact Form Email Notifications (optional) ───────────────────────────────
# If you want to receive email notifications when the form is submitted,
# install nodemailer: npm install nodemailer @types/nodemailer
# Then uncomment the sendNotificationEmail function in src/app/api/contact/route.ts

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=siddiqueshazib5@gmail.com

# ── Analytics (optional) ──────────────────────────────────────────────────────
# For Google Analytics 4 — add your measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Vercel (set automatically by Vercel, do not set manually) ────────────────
# VERCEL_URL is set by Vercel during deployment
# VERCEL_ENV is "production", "preview", or "development"
